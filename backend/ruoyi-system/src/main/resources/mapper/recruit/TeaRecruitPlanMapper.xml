<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.recruit.TeaRecruitPlanMapper">

	<resultMap type="com.ruoyi.system.domain.recruit.TeaRecruitPlan" id="TeaRecruitPlanResult">
		<id     property="planId"       column="plan_id"       />
		<result property="deptId"       column="dept_id"       />
		<result property="discipline"   column="discipline"    />
		<result property="planCount"    column="plan_count"    />
		<result property="actualCount"  column="actual_count"  />
		<result property="talentLevel"  column="talent_level"  />
		<result property="planYear"     column="plan_year"     />
		<result property="status"       column="status"        />
		<result property="createBy"     column="create_by"     />
		<result property="createTime"   column="create_time"   />
		<result property="updateBy"     column="update_by"     />
		<result property="updateTime"   column="update_time"   />
		<result property="remark"       column="remark"        />
		<result property="deptName"     column="dept_name"     />
	</resultMap>

	<sql id="selectRecruitPlanVo">
		select p.plan_id, p.dept_id, p.discipline, p.plan_count, p.actual_count,
			p.talent_level, p.plan_year, p.status, p.create_by, p.create_time,
			p.update_by, p.update_time, p.remark, d.dept_name
		from tea_recruit_plan p
		left join sys_dept d on d.dept_id = p.dept_id
	</sql>

	<select id="selectRecruitPlanList" parameterType="com.ruoyi.system.domain.recruit.TeaRecruitPlan" resultMap="TeaRecruitPlanResult">
		<include refid="selectRecruitPlanVo"/>
		<where>
			<if test="discipline != null and discipline != ''">AND p.discipline like concat('%', #{discipline}, '%')</if>
			<if test="talentLevel != null and talentLevel != ''">AND p.talent_level = #{talentLevel}</if>
			<if test="planYear != null">AND p.plan_year = #{planYear}</if>
			<if test="status != null and status != ''">AND p.status = #{status}</if>
			<if test="deptId != null">AND p.dept_id = #{deptId}</if>
		</where>
		order by p.plan_id desc
	</select>

	<select id="selectRecruitPlanById" parameterType="Long" resultMap="TeaRecruitPlanResult">
		<include refid="selectRecruitPlanVo"/>
		where p.plan_id = #{planId}
	</select>

	<insert id="insertRecruitPlan" parameterType="com.ruoyi.system.domain.recruit.TeaRecruitPlan" useGeneratedKeys="true" keyProperty="planId">
		insert into tea_recruit_plan(
			<if test="deptId != null">dept_id,</if>
			<if test="discipline != null and discipline != ''">discipline,</if>
			<if test="planCount != null">plan_count,</if>
			<if test="actualCount != null">actual_count,</if>
			<if test="talentLevel != null and talentLevel != ''">talent_level,</if>
			<if test="planYear != null">plan_year,</if>
			<if test="status != null and status != ''">status,</if>
			<if test="remark != null">remark,</if>
			<if test="createBy != null and createBy != ''">create_by,</if>
			create_time
		)values(
			<if test="deptId != null">#{deptId},</if>
			<if test="discipline != null and discipline != ''">#{discipline},</if>
			<if test="planCount != null">#{planCount},</if>
			<if test="actualCount != null">#{actualCount},</if>
			<if test="talentLevel != null and talentLevel != ''">#{talentLevel},</if>
			<if test="planYear != null">#{planYear},</if>
			<if test="status != null and status != ''">#{status},</if>
			<if test="remark != null">#{remark},</if>
			<if test="createBy != null and createBy != ''">#{createBy},</if>
			sysdate()
		)
	</insert>

	<update id="updateRecruitPlan" parameterType="com.ruoyi.system.domain.recruit.TeaRecruitPlan">
		update tea_recruit_plan
		<set>
			<if test="deptId != null">dept_id = #{deptId},</if>
			<if test="discipline != null">discipline = #{discipline},</if>
			<if test="planCount != null">plan_count = #{planCount},</if>
			<if test="actualCount != null">actual_count = #{actualCount},</if>
			<if test="talentLevel != null">talent_level = #{talentLevel},</if>
			<if test="planYear != null">plan_year = #{planYear},</if>
			<if test="status != null and status != ''">status = #{status},</if>
			<if test="remark != null">remark = #{remark},</if>
			<if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
			update_time = sysdate()
		</set>
		where plan_id = #{planId}
	</update>

	<delete id="deleteRecruitPlanByIds" parameterType="Long">
		delete from tea_recruit_plan where plan_id in
		<foreach collection="array" item="planId" open="(" separator="," close=")">#{planId}</foreach>
	</delete>
</mapper>
