<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.recruit.TeaApplicantWorkMapper">

	<resultMap type="com.ruoyi.system.domain.recruit.TeaApplicantWork" id="Result">
		<id     property="workId"       column="work_id"       />
		<result property="applicantId"  column="applicant_id"  />
		<result property="startDate"    column="start_date"    />
		<result property="endDate"      column="end_date"      />
		<result property="unit"         column="unit"          />
		<result property="position"     column="position"      />
		<result property="description"  column="description"   />
	</resultMap>

	<select id="selectWorkByApplicantId" parameterType="Long" resultMap="Result">
		select work_id, applicant_id, start_date, end_date, unit, position, description
		from tea_applicant_work where applicant_id = #{applicantId} order by start_date asc
	</select>

	<insert id="insertApplicantWork" parameterType="com.ruoyi.system.domain.recruit.TeaApplicantWork" useGeneratedKeys="true" keyProperty="workId">
		insert into tea_applicant_work(
			applicant_id,
			<if test="startDate != null">start_date,</if>
			<if test="endDate != null">end_date,</if>
			<if test="unit != null and unit != ''">unit,</if>
			<if test="position != null and position != ''">position,</if>
			<if test="description != null and description != ''">description,</if>
			work_id
		)values(
			#{applicantId},
			<if test="startDate != null">#{startDate},</if>
			<if test="endDate != null">#{endDate},</if>
			<if test="unit != null and unit != ''">#{unit},</if>
			<if test="position != null and position != ''">#{position},</if>
			<if test="description != null and description != ''">#{description},</if>
			0
		)
	</insert>

	<delete id="deleteWorkByApplicantId" parameterType="Long">
		delete from tea_applicant_work where applicant_id = #{applicantId}
	</delete>
</mapper>
