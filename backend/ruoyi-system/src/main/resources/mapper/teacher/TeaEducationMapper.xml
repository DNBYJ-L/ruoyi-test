<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.teacher.TeaEducationMapper">

	<resultMap type="com.ruoyi.system.domain.teacher.TeaEducation" id="TeaEducationResult">
		<id     property="educationId"    column="education_id"    />
		<result property="teacherId"      column="teacher_id"      />
		<result property="educationLevel" column="education_level" />
		<result property="graduateSchool" column="graduate_school" />
		<result property="major"          column="major"           />
		<result property="degreeType"     column="degree_type"     />
		<result property="obtainDate"     column="obtain_date"     />
		<result property="isHighest"      column="is_highest"      />
		<result property="createBy"       column="create_by"       />
		<result property="createTime"     column="create_time"     />
		<result property="updateBy"       column="update_by"       />
		<result property="updateTime"     column="update_time"     />
	</resultMap>

	<select id="selectEducationByTeacherId" parameterType="Long" resultMap="TeaEducationResult">
		select education_id, teacher_id, education_level, graduate_school, major,
			degree_type, obtain_date, is_highest, create_by, create_time
		from tea_education
		where teacher_id = #{teacherId}
		order by obtain_date asc
	</select>

	<insert id="insertEducation" parameterType="com.ruoyi.system.domain.teacher.TeaEducation" useGeneratedKeys="true" keyProperty="educationId">
		insert into tea_education(
			<if test="teacherId != null">teacher_id,</if>
			<if test="educationLevel != null and educationLevel != ''">education_level,</if>
			<if test="graduateSchool != null and graduateSchool != ''">graduate_school,</if>
			<if test="major != null and major != ''">major,</if>
			<if test="degreeType != null and degreeType != ''">degree_type,</if>
			<if test="obtainDate != null">obtain_date,</if>
			<if test="isHighest != null and isHighest != ''">is_highest,</if>
			<if test="createBy != null and createBy != ''">create_by,</if>
			create_time
		)values(
			<if test="teacherId != null">#{teacherId},</if>
			<if test="educationLevel != null and educationLevel != ''">#{educationLevel},</if>
			<if test="graduateSchool != null and graduateSchool != ''">#{graduateSchool},</if>
			<if test="major != null and major != ''">#{major},</if>
			<if test="degreeType != null and degreeType != ''">#{degreeType},</if>
			<if test="obtainDate != null">#{obtainDate},</if>
			<if test="isHighest != null and isHighest != ''">#{isHighest},</if>
			<if test="createBy != null and createBy != ''">#{createBy},</if>
			sysdate()
		)
	</insert>

	<update id="updateEducation" parameterType="com.ruoyi.system.domain.teacher.TeaEducation">
		update tea_education
		<set>
			<if test="educationLevel != null and educationLevel != ''">education_level = #{educationLevel},</if>
			<if test="graduateSchool != null">graduate_school = #{graduateSchool},</if>
			<if test="major != null">major = #{major},</if>
			<if test="degreeType != null">degree_type = #{degreeType},</if>
			<if test="obtainDate != null">obtain_date = #{obtainDate},</if>
			<if test="isHighest != null">is_highest = #{isHighest},</if>
			<if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
			update_time = sysdate()
		</set>
		where education_id = #{educationId}
	</update>

	<delete id="deleteEducationByTeacherId" parameterType="Long">
		delete from tea_education where teacher_id = #{teacherId}
	</delete>

	<delete id="deleteEducationByTeacherIds" parameterType="Long">
		delete from tea_education where teacher_id in
		<foreach collection="array" item="teacherId" open="(" separator="," close=")">
			#{teacherId}
		</foreach>
	</delete>

</mapper>
