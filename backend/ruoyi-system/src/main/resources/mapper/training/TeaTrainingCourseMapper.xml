<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.training.TeaTrainingCourseMapper">
	<resultMap type="com.ruoyi.system.domain.training.TeaTrainingCourse" id="Result">
		<id property="courseId" column="course_id"/>
		<result property="planId" column="plan_id"/>
		<result property="courseName" column="course_name"/>
		<result property="instructor" column="instructor"/>
		<result property="hours" column="hours"/>
		<result property="sortOrder" column="sort_order"/>
		<result property="description" column="description"/>
	</resultMap>
	<select id="selectCourseByPlanId" parameterType="Long" resultMap="Result">
		select course_id, plan_id, course_name, instructor, hours, sort_order, description
		from tea_training_course where plan_id = #{planId} order by sort_order asc
	</select>
	<insert id="insertTrainingCourse" parameterType="com.ruoyi.system.domain.training.TeaTrainingCourse" useGeneratedKeys="true" keyProperty="courseId">
		insert into tea_training_course(plan_id, course_name, instructor, hours, sort_order, description)
		values(#{planId}, #{courseName}, #{instructor}, #{hours}, #{sortOrder}, #{description})
	</insert>
	<delete id="deleteCourseByPlanId" parameterType="Long">
		delete from tea_training_course where plan_id = #{planId}
	</delete>
</mapper>
