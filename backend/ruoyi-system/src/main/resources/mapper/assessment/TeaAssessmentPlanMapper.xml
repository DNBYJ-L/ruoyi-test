<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.assessment.TeaAssessmentPlanMapper">
	<resultMap type="com.ruoyi.system.domain.assessment.TeaAssessmentPlan" id="Result">
		<id property="planId" column="plan_id"/>
		<result property="planName" column="plan_name"/>
		<result property="assessmentType" column="assessment_type"/>
		<result property="assessmentYear" column="assessment_year"/>
		<result property="startDate" column="start_date"/>
		<result property="endDate" column="end_date"/>
		<result property="status" column="status"/>
		<result property="createBy" column="create_by"/>
		<result property="createTime" column="create_time"/>
		<result property="updateBy" column="update_by"/>
		<result property="updateTime" column="update_time"/>
		<result property="remark" column="remark"/>
	</resultMap>
	<select id="selectAssessmentPlanList" parameterType="com.ruoyi.system.domain.assessment.TeaAssessmentPlan" resultMap="Result">
		select * from tea_assessment_plan
		<where>
			<if test="planName != null and planName != ''">AND plan_name like concat('%', #{planName}, '%')</if>
			<if test="assessmentType != null and assessmentType != ''">AND assessment_type = #{assessmentType}</if>
			<if test="assessmentYear != null">AND assessment_year = #{assessmentYear}</if>
			<if test="status != null and status != ''">AND status = #{status}</if>
		</where>
		order by plan_id desc
	</select>
	<select id="selectAssessmentPlanById" parameterType="Long" resultMap="Result">
		select * from tea_assessment_plan where plan_id = #{planId}
	</select>
	<insert id="insertAssessmentPlan" parameterType="com.ruoyi.system.domain.assessment.TeaAssessmentPlan" useGeneratedKeys="true" keyProperty="planId">
		insert into tea_assessment_plan(
			<if test="planName != null and planName != ''">plan_name,</if>
			<if test="assessmentType != null and assessmentType != ''">assessment_type,</if>
			<if test="assessmentYear != null">assessment_year,</if>
			<if test="startDate != null">start_date,</if>
			<if test="endDate != null">end_date,</if>
			<if test="status != null and status != ''">status,</if>
			<if test="remark != null">remark,</if>
			<if test="createBy != null and createBy != ''">create_by,</if>
			create_time
		)values(
			<if test="planName != null and planName != ''">#{planName},</if>
			<if test="assessmentType != null and assessmentType != ''">#{assessmentType},</if>
			<if test="assessmentYear != null">#{assessmentYear},</if>
			<if test="startDate != null">#{startDate},</if>
			<if test="endDate != null">#{endDate},</if>
			<if test="status != null and status != ''">#{status},</if>
			<if test="remark != null">#{remark},</if>
			<if test="createBy != null and createBy != ''">#{createBy},</if>
			sysdate()
		)
	</insert>
	<update id="updateAssessmentPlan" parameterType="com.ruoyi.system.domain.assessment.TeaAssessmentPlan">
		update tea_assessment_plan
		<set>
			<if test="planName != null">plan_name = #{planName},</if>
			<if test="assessmentType != null">assessment_type = #{assessmentType},</if>
			<if test="assessmentYear != null">assessment_year = #{assessmentYear},</if>
			<if test="startDate != null">start_date = #{startDate},</if>
			<if test="endDate != null">end_date = #{endDate},</if>
			<if test="status != null and status != ''">status = #{status},</if>
			<if test="remark != null">remark = #{remark},</if>
			<if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
			update_time = sysdate()
		</set>
		where plan_id = #{planId}
	</update>
	<delete id="deleteAssessmentPlanByIds" parameterType="Long">
		delete from tea_assessment_plan where plan_id in
		<foreach collection="array" item="planId" open="(" separator="," close=")">#{planId}</foreach>
	</delete>
</mapper>
